{"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"canvas-logo.png"}]},{"anchor":"What-is-Canvas","level":3,"type":"heading","text":"What is Canvas?"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Canvas allows users to capture spaces in 3D and convert them to a CAD\/BIM model, a floor plan, or a report with measurements using the Canvas Scan To CAD service. Canvas saves hours on measuring and modeling as-builts."},{"type":"text","text":" "},{"type":"text","text":"Scanning takes about only a minute per room or 20 minutes for a typical home. Scan To CAD conversion is a semi-automated process that takes 1-2 business days. The resulting CAD model or a floor plan are 99% accurate, on average, when compared to manual measurements."}]},{"anchor":"Canvas-SDK","level":3,"type":"heading","text":"Canvas SDK"},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"General info"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/img.shields.io\/badge\/swift-5-orange?style=flat&logo=swift"}]}],[{"type":"paragraph","inlineContent":[{"type":"image","identifier":"https:\/\/img.shields.io\/badge\/platfroms-iOS14+-lightgray?style=flat&logo=apple"}]}]]],"header":"row"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Canvas SDK allows partners to integrate Canvas’s functionality into their app. This functionality includes:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Scanning"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Viewing of scans and CAD models"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Placing Scan To CAD orders"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Uploading scans for processing"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Receiving order status and files"}]}]}]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Canvas SDK is only for iOS devices. The initial version of Canvas SDK supports only LiDAR iOS devices: iPhone 12 Pro \/ Pro Max, iPhone 13 Pro \/ Pro Max, iPhone 14 Pro \/ Pro Max, and iPad Pros from 2020 or later. LiDAR devices provide the best accuracy and the most robust capture experience."}]}],"type":"aside","name":"Important"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Please see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.occipital.CanvasSDK\/documentation\/CanvasSDK\/GettingStarted"},{"type":"text","text":" for more detailed information on how to setup and start working with Canvas SDK in your project."}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/canvassdk"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/com.occipital.CanvasSDK\/documentation\/CanvasSDK","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Create a 3D scan of your environment using a device’s camera and convert it to a CAD model."}],"kind":"symbol","metadata":{"roleHeading":"Framework","externalID":"CanvasSDK","title":"CanvasSDK","symbolKind":"module","role":"collection","modules":[{"name":"CanvasSDK"}]},"hierarchy":{"paths":[[]]},"topicSections":[{"title":"Essentials","identifiers":["doc:\/\/com.occipital.CanvasSDK\/documentation\/CanvasSDK\/GettingStarted","doc:\/\/com.occipital.CanvasSDK\/documentation\/CanvasSDK\/Canvas"]},{"title":"Authorization","identifiers":["doc:\/\/com.occipital.CanvasSDK\/documentation\/CanvasSDK\/CanvasSignature","doc:\/\/com.occipital.CanvasSDK\/documentation\/CanvasSDK\/CanvasTokenProvider"]},{"title":"Scanner","identifiers":["doc:\/\/com.occipital.CanvasSDK\/documentation\/CanvasS